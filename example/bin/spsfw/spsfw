#!/bin/bash

# SPSFW CLI - Generator for SPS Framework
VERSION="2.1.0"

# Default namespace prefix
NAMESPACE_PREFIX="SpsNext"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Find SPSFW directory
find_spsfw_dir() {
    local script_path="$0"

    if [[ -L "$script_path" ]]; then
        script_path="$(readlink -f "$script_path" 2>/dev/null || echo "$script_path")"
    fi

    echo "$(cd "$(dirname "$script_path")" && pwd)"
}

# Initialize paths
SPSFW_DIR="$(find_spsfw_dir)"
TEMPLATE_DIR="$SPSFW_DIR/templates"
CONFIG_FILE="$SPSFW_DIR/.spsfw-config"

# Default template files
CONTROLLER_TEMPLATE="$TEMPLATE_DIR/Controller.php.template"
SERVICE_TEMPLATE="$TEMPLATE_DIR/Service.php.template"
STORAGE_TEMPLATE="$TEMPLATE_DIR/Storage.php.template"

# Show help
show_help() {
    echo -e "${BLUE}SPSFW CLI v${VERSION}${NC}"
    echo ""
    echo -e "${GREEN}Генератор разделов и методов${NC}"
    echo ""
    echo "Usage:"
    echo "  spsfw make:chapter <name>           Создание раздела"
    echo "  spsfw make:chapter <parent/child>   Создание дочернего раздела"
    echo "  spsfw make:api <params>             Создание API роута"
    echo ""
    echo "  spsfw --help"
    echo "  spsfw --version"
    echo "  spsfw --set-root <path>            Указать корень проекта"
    echo "  spsfw --set-namespace <ns>         Указать namespace"
    echo "  spsfw --show-paths                 показать пути"
    echo "  spsfw --init                       инициализация"
    echo ""
    echo "API примеры:"
        echo "  spsfw make:api Products '/api/products' getAll GET"
        echo "  spsfw make:api Products '/api/products/{id}' getById GET -v"
        echo "  spsfw make:api Products '/api/products/{id:int}' updateItem PUT"
        echo "  spsfw make:api Products '/api/products/{uuid}' deleteRecord DELETE -v"
        echo "  spsfw make:api                       # интерактивный мод"
        echo ""
        echo "Chapter примеры:"
        echo "  spsfw make:chapter Users           # Одиночный раздел"
        echo "  spsfw make:chapter Products/API    # Дочерний раздел"
        echo "  spsfw make:chapter Shop/Cart       # одиночный с дочерним"
        echo "  spsfw --set-namespace SpsNext\\LK"
}

# Load config
load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE" 2>/dev/null
    fi

    # Set default project root if not set
    if [[ -z "$PROJECT_ROOT" ]]; then
        # Try to find project root
        local current_dir="$PWD"
        while [[ "$current_dir" != "/" ]]; do
            if [[ -f "$current_dir/composer.json" ]] || \
               [[ -d "$current_dir/src" ]]; then
                PROJECT_ROOT="$current_dir"
                break
            fi
            current_dir="$(dirname "$current_dir")"
        done

        # Fallback to current directory
        if [[ -z "$PROJECT_ROOT" ]]; then
            PROJECT_ROOT="$PWD"
        fi
    fi

    TARGET_DIR="${PROJECT_ROOT}/src"
}

# Save config
save_config() {
    cat > "$CONFIG_FILE" << EOF
PROJECT_ROOT="$PROJECT_ROOT"
NAMESPACE_PREFIX="$NAMESPACE_PREFIX"
EOF
}

# Convert to CamelCase
to_camel_case() {
    echo "$1" | sed -r 's/(^|_)([a-z])/\U\2/g'
}

# Convert to lowercase first letter
lcfirst() {
    echo "$1" | sed 's/^./\L&/'
}

# Get chapter name from path
get_chapter_name() {
    local path="$1"
    # Extract last part after /
    echo "$path" | awk -F'/' '{print $NF}'
}

# Get parent path
get_parent_path() {
    local path="$1"
    # Remove last part
    echo "$path" | sed 's|/[^/]*$||'
}

# Create directory if not exists
safe_mkdir() {
    local dir="$1"
    if [[ ! -d "$dir" ]]; then
        mkdir -p "$dir"
        return 0
    fi
    return 1
}

# Check if directory is empty (except .gitkeep)
is_dir_empty() {
    local dir="$1"
    local count=$(find "$dir" -maxdepth 1 -type f ! -name 'readme.txt' 2>/dev/null | wc -l)
    [[ $count -eq 0 ]] && return 0
    return 1
}

# Check if directory is a chapter (has expected structure)
is_chapter_dir() {
    local dir="$1"
    [[ -d "$dir/Controllers" && -d "$dir/Services" && -d "$dir/Storages" ]] && return 0
    return 1
}

# Create chapter
make_chapter() {
    local chapter_path="$1"

    if [[ -z "$chapter_path" ]]; then
        echo -e "${RED}Error: Chapter name is required${NC}"
        exit 1
    fi

    load_config

    local chapter_name=$(get_chapter_name "$chapter_path")
    local parent_path=$(get_parent_path "$chapter_path")
    local full_target_path="$TARGET_DIR/$chapter_path"
    local parent_target_path="$TARGET_DIR/$parent_path"

    echo -e "${BLUE}Creating chapter: $chapter_path${NC}"
    echo -e "${YELLOW}Chapter name: $chapter_name${NC}"

    if [[ -n "$parent_path" ]]; then
        echo -e "${YELLOW}Parent: $parent_path${NC}"
    fi

    echo -e "${YELLOW}Target: $full_target_path${NC}"
    echo ""

    # Check if we're creating a nested chapter
    if [[ -n "$parent_path" ]]; then
        # Check parent directory
        if [[ -d "$parent_target_path" ]]; then
            if is_chapter_dir "$parent_target_path"; then
                echo -e "${YELLOW}Parent '$parent_path' is already a chapter structure${NC}"
                echo -e "${YELLOW}Creating '$chapter_name' as nested chapter inside existing chapter${NC}"
            else
                echo -e "${GREEN}Parent '$parent_path' exists, will create nested chapter${NC}"
            fi
        else
            echo -e "${YELLOW}Parent '$parent_path' doesn't exist. Creating empty parent directory...${NC}"
            safe_mkdir "$parent_target_path"
            echo -e "  ✓ Created empty parent directory"
        fi
    fi

    # Check if target directory exists
    if [[ -d "$full_target_path" ]]; then
        if is_chapter_dir "$full_target_path"; then
            echo -e "${YELLOW}Chapter '$chapter_path' already exists as a chapter structure${NC}"
            echo -e "${YELLOW}Overwrite? This will delete all existing files in the chapter. (y/N)${NC}"
            read -r response
            if [[ ! "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
                echo "Aborted."
                exit 0
            fi
            rm -rf "$full_target_path"
        else
            echo -e "${YELLOW}Directory '$chapter_path' exists but is not a chapter structure${NC}"
            echo -e "${YELLOW}Add chapter structure to existing directory? (y/N)${NC}"
            read -r response
            if [[ ! "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
                echo "Aborted."
                exit 0
            fi
            # Don't delete, just add structure
        fi
    fi

    # Create main directory if needed
    safe_mkdir "$full_target_path" && echo -e "${GREEN}Created directory: $chapter_path${NC}"

    # Create directories
    echo -e "${GREEN}Creating chapter structure...${NC}"

    local directories=("Controllers" "Services" "Storages" "Entities" "Entities/migrations" "DTOs" "Enums")
    local dirs_created=0

    for dir in "${directories[@]}"; do
        local dir_path="$full_target_path/$dir"
        if safe_mkdir "$dir_path"; then
            echo -e "  ✓ $dir"
            ((dirs_created++))
        else
            echo -e "  ⚠ $dir (already exists)"
        fi

        # Add .gitkeep to empty directories
        if [[ "$dir" == "Entities" || "$dir" == "DTOs" || "$dir" == "Enums" ]]; then
            if [[ ! -f "$dir_path/.gitkeep" ]]; then
                touch "$dir_path/.gitkeep"
            fi
        fi
    done

    echo ""

    # Build namespace
    local namespace_parts=()
    IFS='/' read -ra PARTS <<< "$chapter_path"

    # Start with base namespace
    namespace_parts+=("$NAMESPACE_PREFIX")

    # Add each part in CamelCase
    for part in "${PARTS[@]}"; do
        namespace_parts+=("$(to_camel_case "$part")")
    done

    local full_namespace=$(IFS='\\'; echo "${namespace_parts[*]}")
    local last_namespace="${namespace_parts[-1]}"
    local var_name=$(lcfirst "$last_namespace")

    # Create files only if directories were created or don't exist
    echo -e "${GREEN}Создание файлов...${NC}"

    # Create Controller
    local controller_file="$full_target_path/Controllers/${last_namespace}Controller.php"
    if [[ ! -f "$controller_file" ]] || [[ $dirs_created -gt 0 ]]; then
        cat > "$controller_file" << EOF
<?php

declare(strict_types=1);

namespace ${full_namespace}\Controllers;

use SpsFW\Core\Attributes\Controller;
use OpenApi\Attributes as OA;
use SpsFW\Core\Attributes\Inject;
use SpsFW\Core\Attributes\Route;
use SpsFW\Core\Attributes\Validation\QueryParams;
use SpsFW\Core\Http\Response;
use SpsFW\Core\Route\RestController;
use ${full_namespace}\Services\\${last_namespace}Service;

#[Controller]
#[OA\Tag(name: "${var_name}", description: "API для работы с ${var_name}")]
class ${last_namespace}Controller extends RestController
{
    public function __construct(
        #[Inject] private ${last_namespace}Service \$${var_name}Service
    )
    {
        parent::__construct();
    }

    // TODO: Add routes here
}
EOF
        echo -e "  ✓ Controllers/${last_namespace}Controller.php"
    else
        echo -e "  ⚠ Controllers/${last_namespace}Controller.php (Уже существует)"
    fi

    # Create Service
    local service_file="$full_target_path/Services/${last_namespace}Service.php"
    if [[ ! -f "$service_file" ]] || [[ $dirs_created -gt 0 ]]; then
        cat > "$service_file" << EOF
<?php

declare(strict_types=1);

namespace ${full_namespace}\Services;

use SpsFW\Core\Attributes\Inject;
use ${full_namespace}\Storages\\${last_namespace}Storage;

class ${last_namespace}Service
{
    public function __construct(
        #[Inject] private ${last_namespace}Storage \$${var_name}Storage
    ) {}

    // TODO: Add service methods here
}
EOF
        echo -e "  ✓ Services/${last_namespace}Service.php"
    else
        echo -e "  ⚠ Services/${last_namespace}Service.php (Уже существует)"
    fi

    # Create Storage
    local storage_file="$full_target_path/Storages/${last_namespace}Storage.php"
    if [[ ! -f "$storage_file" ]] || [[ $dirs_created -gt 0 ]]; then
        cat > "$storage_file" << EOF
<?php

declare(strict_types=1);

namespace ${full_namespace}\Storages;

use PDO;
use SpsFW\Core\Storage\PdoStorage;

class ${last_namespace}Storage extends PdoStorage
{
    // TODO: Add storage methods here
}
EOF
        echo -e "  ✓ Storages/${last_namespace}Storage.php"
    else
        echo -e "  ⚠ Storages/${last_namespace}Storage.php (already exists)"
    fi

     # Create MigrationRequiredClass
        local migration_file="$full_target_path/Entities/MigrationRequiredClass.php"
        if [[ ! -f "$migration_file" ]] || [[ $dirs_created -gt 0 ]]; then
            cat > "$migration_file" << EOF
<?php

namespace ${full_namespace}\Entities;

class MigrationRequiredClass
{
    // TODO: Infrastructure class. Need for correct creating migration by Phinx
    // using:  php vendor/bin/phinx create
    // then select wished path

}
EOF
             echo -e "  ✓ Entities/MigrationRequiredClass.php"
        else
            echo -e "  ⚠ Entities/MigrationRequiredClass.php (already exists)"
        fi

    echo ""
    echo -e "${GREEN}✓ Chapter '$chapter_path' created successfully!${NC}"
    echo -e "${BLUE}Path: $full_target_path${NC}"
    echo -e "${BLUE}Namespace: ${full_namespace}${NC}"

    echo ""
    echo -e "${YELLOW}Structure:${NC}"
    find "$full_target_path" -type f | sort | sed "s|^$TARGET_DIR/||" | sed 's/^/  /'
}

# Show current paths
show_paths() {
    load_config
    echo -e "${BLUE}Current paths:${NC}"
    echo "  Project root:    $PROJECT_ROOT"
    echo "  Target dir:      $TARGET_DIR"
    echo "  Namespace:       $NAMESPACE_PREFIX"
    echo "  Script dir:      $SPSFW_DIR"
}

# Set project root
set_project_root() {
    local new_root="$1"

    if [[ -z "$new_root" ]]; then
        echo -e "${RED}Error: Path is required${NC}"
        exit 1
    fi

    if [[ ! -d "$new_root" ]]; then
        mkdir -p "$new_root"
    fi

    PROJECT_ROOT="$new_root"
    TARGET_DIR="$PROJECT_ROOT/src"
    save_config

    echo -e "${GREEN}✓ Project root set to: $new_root${NC}"
}

# Set namespace prefix
set_namespace() {
    local new_namespace="$1"

    if [[ -z "$new_namespace" ]]; then
        echo -e "${RED}Error: Namespace is required${NC}"
        exit 1
    fi

    NAMESPACE_PREFIX="$new_namespace"
    save_config

    echo -e "${GREEN}✓ Namespace set to: $new_namespace${NC}"
}

# Create API endpoint
# Create API endpoint
# Create API endpoint
make_api() {
    local interactive=false
    local chapter_path=""
    local route=""
    local method_name=""
    local http_methods=""
    local verbose_response=false

    # Parse arguments
    local args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            "-v")
                verbose_response=true
                shift
                ;;
            *)
                args+=("$1")
                shift
                ;;
        esac
    done

    # Assign arguments
    if [[ ${#args[@]} -ge 1 ]]; then
        chapter_path="${args[0]}"
    fi
    if [[ ${#args[@]} -ge 2 ]]; then
        route="${args[1]}"
    fi
    if [[ ${#args[@]} -ge 3 ]]; then
        method_name="${args[2]}"
    fi
    if [[ ${#args[@]} -ge 4 ]]; then
        http_methods="${args[3]}"
    fi

    # Interactive mode
    if [[ -z "$chapter_path" ]]; then
        echo -e "${BLUE}API Generator - Интерактивный мод:${NC}"
        echo ""
        echo -e "${YELLOW}Введите название раздела (можно вложенный, например Products/Test):${NC}"
        read -r chapter_path
        echo -e "${YELLOW}Введите маршрут (например: /api/products/{id}):${NC}"
        read -r route
        echo -e "${YELLOW}Введите имя метода (camelCase, например: getById):${NC}"
        read -r method_name
        echo -e "${YELLOW}Введите HTTP методы через запятую (например: GET,POST):${NC}"
        read -r http_methods
        echo -e "${YELLOW}Добавить шаблонный ответ? (y/N):${NC}"
        read -r add_verbose
        if [[ "$add_verbose" =~ ^([yY][eE][sS]|[yY])$ ]]; then
            verbose_response=true
        fi
    fi

    # Validate required parameters
    if [[ -z "$chapter_path" ]] || [[ -z "$route" ]] || [[ -z "$method_name" ]] || [[ -z "$http_methods" ]]; then
        echo -e "${RED}Error: Missing required parameters${NC}"
        echo "Usage: spsfw make:api <chapter> <route> <method> <http_methods> [-v]"
        echo "Example: spsfw make:api Products/Test '/api/products/{id}' getById GET -v"
        exit 1
    fi

    load_config

    local chapter_dir="$TARGET_DIR/$chapter_path"
    local chapter_name=$(get_chapter_name "$chapter_path")

    # Check if chapter exists
    if [[ ! -d "$chapter_dir" ]]; then
        echo -e "${RED}Error: Chapter '$chapter_path' not found${NC}"
        echo -e "${YELLOW}Would you like to create it? (y/N)${NC}"
        read -r response
        if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
            echo ""
            make_chapter "$chapter_path"
            echo ""
            echo -e "${GREEN}Now adding API endpoint...${NC}"
        else
            exit 1
        fi
    fi

    # Build namespace parts
    local namespace_parts=()
    IFS='/' read -ra PARTS <<< "$chapter_path"

    # Start with base namespace
    namespace_parts+=("$NAMESPACE_PREFIX")

    # Add each part in CamelCase
    for part in "${PARTS[@]}"; do
        namespace_parts+=("$(to_camel_case "$part")")
    done

    local full_namespace=$(IFS='\\'; echo "${namespace_parts[*]}")
    local last_namespace="${namespace_parts[-1]}"
    local var_name=$(lcfirst "$last_namespace")

    local controller_file="$chapter_dir/Controllers/${last_namespace}Controller.php"

    # Check if controller exists
    if [[ ! -f "$controller_file" ]]; then
        echo -e "${RED}Error: Controller not found: $controller_file${NC}"
        echo -e "${YELLOW}Would you like to create it? (y/N)${NC}"
        read -r response
        if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
            # Create controller manually
            mkdir -p "$(dirname "$controller_file")"
            cat > "$controller_file" << EOF
<?php

declare(strict_types=1);

namespace ${full_namespace}\Controllers;

use SpsFW\Core\Attributes\Controller;
use OpenApi\Attributes as OA;
use SpsFW\Core\Attributes\Inject;
use SpsFW\Core\Attributes\Route;
use SpsFW\Core\Attributes\Validation\QueryParams;
use SpsFW\Core\Http\Response;
use SpsFW\Core\Route\RestController;
use ${full_namespace}\Services\\${last_namespace}Service;

#[Controller]
#[OA\Tag(name: "${var_name}", description: "API для работы с ${var_name}")]
class ${last_namespace}Controller extends RestController
{
    public function __construct(
        #[Inject] private ${last_namespace}Service \$${var_name}Service
    )
    {
        parent::__construct();
    }

    // TODO: Add routes here
}
EOF
            echo -e "${GREEN}✓ Created controller: $controller_file${NC}"
        else
            exit 1
        fi
    fi

    # Check if method already exists in controller
    if grep -q "public function $method_name" "$controller_file"; then
        echo -e "${RED}Error: Method '$method_name' already exists in controller${NC}"
        exit 1
    fi

    local service_file="$chapter_dir/Services/${last_namespace}Service.php"

    # Check if service exists
    if [[ ! -f "$service_file" ]]; then
        echo -e "${RED}Error: Service not found: $service_file${NC}"
        echo -e "${YELLOW}Would you like to create it? (y/N)${NC}"
        read -r response
        if [[ "$response" =~ ^([yY][eE][sS]|[yY])$ ]]; then
            # Create service manually
            mkdir -p "$(dirname "$service_file")"
            cat > "$service_file" << EOF
<?php

declare(strict_types=1);

namespace ${full_namespace}\Services;

use SpsFW\Core\Attributes\Inject;
use ${full_namespace}\Storages\\${last_namespace}Storage;

class ${last_namespace}Service
{
    public function __construct(
        #[Inject] private ${last_namespace}Storage \$${var_name}Storage
    ) {}

    // TODO: Add service methods here
}
EOF
            echo -e "${GREEN}✓ Created service: $service_file${NC}"
        else
            exit 1
        fi
    fi

    # Check if service method already exists
    if grep -q "public function $method_name" "$service_file"; then
        echo -e "${RED}Error: Method '$method_name' already exists in service${NC}"
        exit 1
    fi

    # Extract parameters from route
    local params=()
    local param_names=()
    local original_route="$route"

    # Find all parameters in route
    while [[ "$route" =~ \{([^}]+)\} ]]; do
        local param="${BASH_REMATCH[1]}"
        local param_name="$param"
        local param_type="string"

        # Check for type hint
        if [[ "$param" == *":"* ]]; then
            param_name=$(echo "$param" | cut -d: -f1)
            local type_hint=$(echo "$param" | cut -d: -f2)
            case "$type_hint" in
                "int"|"integer")
                    param_type="int"
                    ;;
                "uuid"|"string")
                    param_type="string"
                    ;;
                *)
                    param_type="string"
                    ;;
            esac
        fi

        params+=("$param_type \$$param_name")
        param_names+=("$param_name")

        # Remove the parameter from route for next iteration
        route="${route/\{$param\}/}"
    done

    # Prepare HTTP methods array
    local http_methods_array=()
    IFS=',' read -ra http_methods_array <<< "$http_methods"

    local http_methods_str="["
    for i in "${!http_methods_array[@]}"; do
        http_methods_str+="'${http_methods_array[$i]}'"
        if [[ $i -lt $((${#http_methods_array[@]} - 1)) ]]; then
            http_methods_str+=", "
        fi
    done
    http_methods_str+="]"

    # Build method parameters string
    local method_params_str=$(IFS=', '; echo "${params[*]}")

    # Build service call parameters string
    local service_call_params_str=""
    if [[ ${#param_names[@]} -gt 0 ]]; then
        service_call_params_str=$(printf '\$%s, ' "${param_names[@]}")
        service_call_params_str="${service_call_params_str%, }"
    fi

    echo -e "${BLUE}Creating API endpoint...${NC}"
    echo -e "  Chapter: $chapter_path"
    echo -e "  Route: $original_route"
    echo -e "  Method: $method_name"
    echo -e "  HTTP Methods: ${http_methods_array[*]}"
    echo -e "  Parameters: ${params[*]}"
    echo -e "  Template response: $verbose_response"
    echo ""

    # Generate controller method
    local controller_method=""
    if [[ "$verbose_response" == true ]]; then
        controller_method=$(cat <<EOF

    #[Route('$original_route', httpMethods: $http_methods_str)]
    public function $method_name($method_params_str): Response
    {
        \$this->${var_name}Service->$method_name($service_call_params_str);
        return Response::json(data: [
            'status' => 'ok',
            'msg' => 'Успешное выполнение команды'
        ]);
    }
EOF
)
    else
        controller_method=$(cat <<EOF

    #[Route('$original_route', httpMethods: $http_methods_str)]
    public function $method_name($method_params_str): Response
    {
        return Response::json(
            \$this->${var_name}Service->$method_name($service_call_params_str)
        );
    }
EOF
)
    fi

    # Generate service method
    local service_method=$(cat <<EOF

    public function $method_name($method_params_str)
    {
        // TODO: Implement $method_name() method
    }
EOF
)

    # Add method to controller using awk
    awk -v method="$controller_method" '
    /^}$/ && !added {
        print method
        added=1
    }
    {print}
    ' "$controller_file" > "${controller_file}.tmp" && mv "${controller_file}.tmp" "$controller_file"

    echo -e "${GREEN}✓ Added method to controller: $controller_file${NC}"

    # Add method to service using awk
    awk -v method="$service_method" '
    /^}$/ && !added {
        print method
        added=1
    }
    {print}
    ' "$service_file" > "${service_file}.tmp" && mv "${service_file}.tmp" "$service_file"

    echo -e "${GREEN}✓ Added method to service: $service_file${NC}"

    echo ""
    echo -e "${GREEN}✓ API endpoint '$method_name' created successfully!${NC}"
    echo ""
    echo -e "${BLUE}Controller method added:${NC}"
    echo "$controller_method"
    echo ""
    echo -e "${BLUE}Service method added:${NC}"
    echo "$service_method"
}

# Main
main() {
    local command="$1"
    local argument="$2"

    case "$command" in
        "make:chapter")
            make_chapter "$argument"
            ;;
        "make:api")
                    shift
                    make_api "$@"
                    ;;
        "--set-root")
            set_project_root "$argument"
            ;;
        "--set-namespace")
            set_namespace "$argument"
            ;;
        "--show-paths")
            show_paths
            ;;
        "--version"|"-v")
            echo -e "${BLUE}SPSFW CLI v${VERSION}${NC}"
            ;;
        "--help"|"-h"|"")
            show_help
            ;;
        *)
            echo -e "${RED}Error: Unknown command '$command'${NC}"
            show_help
            exit 1
            ;;
    esac
}

main "$@"